generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role           @default(PUBLIC)
  isActive      Boolean        @default(true)
  permissions   Json           @default("[]")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  content       String   @db.Text
  summary       String?  @db.Text
  coverImage    String?
  published     Boolean  @default(false)
  publishedAt   DateTime?
  
  authorId      String
  author        User     @relation(fields: [authorId], references: [id])
  
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  
  tags          Tag[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  PUBLIC
  MEMBER
  SUPPLIER
  ADMIN
  WRITER
}

model AtaRegistro {
  id                      String    @id @default(cuid())
  titulo                  String
  slug                    String    @unique
  numeroAta               String
  ultimaAtualizacao       DateTime?
  local                   String?
  orgao                   String
  modalidadeContratacao   String?
  dataDivulgacaoPncp      DateTime?
  dataAssinatura          DateTime?
  vigenciaInicio          DateTime?
  vigenciaFim             DateTime?
  idAtaPncp               String?
  fonte                   String?
  idContratacaoPncp       String?
  objeto                  String    @db.Text
  resumo                  String?   @db.Text
  published               Boolean   @default(false)
  
  arquivos                AtaRegistroArquivo[]

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model AtaRegistroArquivo {
  id             String       @id @default(cuid())
  nomeArquivo    String
  urlArquivo     String
  tipoArquivo    String?
  ordem          Int          @default(0)
  
  ataRegistroId  String
  ataRegistro    AtaRegistro  @relation(fields: [ataRegistroId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
}

model CatalogCategory {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  description    String?          @db.Text
  coverImage     String?
  icon           String?
  order          Int              @default(0)
  active         Boolean          @default(true)
  products       CatalogProduct[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model CatalogBrand {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  logo           String?
  coverImage     String?          // Foto de fundo para o carrossel
  description    String?          @db.Text
  order          Int              @default(0)
  active         Boolean          @default(true)
  products       CatalogProduct[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model CatalogProduct {
  id                     String          @id @default(cuid())
  name                   String
  slug                   String          @unique
  
  brandId                String?
  brand                  CatalogBrand?   @relation(fields: [brandId], references: [id])
  
  categoryId             String?
  category               CatalogCategory? @relation(fields: [categoryId], references: [id])
  
  mainImage              String?
  galleryImages          Json?           @default("[]")
  
  classification         String?         // Leve, Médio, Pesado
  condition              String?         @default("NOVO") // NOVO, USADO, LOCACAO
  shortDescription       String?         @db.Text
  fullDescription        String?         @db.Text
  
  // Especificações Rápidas (Icons padrão)
  weight                 String?         // Peso Operacional
  power                  String?         // Potência
  bucketCapacity         String?         // Caçamba
  
  serviceDifferential    String?         @db.Text // Seção Nível de Serviço
  recommendationText     String?         @db.Text
  highlightApplications  Json?           @default("[]")
  
  technicalData          Json?           @default("[]")
  technicalFiles         Json?           @default("[]")
  differentials          Json?           @default("[]")
  recommendedApplications Json?           @default("[]")
  relatedProducts        Json?           @default("[]")
  
  metaTitle              String?
  metaDescription        String?
  ogImage                String?
  
  productType            String?         @default("machine") // "machine" | "engine" | "part" | "service"
  engineCode             String?
  mainFeaturesHtml       String?         @db.Text
  technicalInfoTable     Json?
  technicalInfoHtml      String?         @db.Text
  
  featured               Boolean         @default(false)
  order                  Int             @default(0)
  active                 Boolean         @default(true)
  
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  // Índices de performance para os filtros públicos do catálogo
  @@index([brandId])
  @@index([categoryId])
  @@index([active])
  @@index([active, productType, createdAt(sort: Desc)])
}

model JobApplication {
  id            String   @id @default(cuid())
  nome          String
  email         String
  telefone      String
  areaInteresse String
  sobre         String   @db.Text
  curriculoUrl  String
  status        String   @default("PENDENTE") // PENDENTE, ANALISE, REPROVADO, APROVADO
  internalNotes String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Lead {
  id            String   @id @default(cuid())
  type          String   // 'ASSISTANCE', 'PRODUCT_QUOTE', 'CONTACT', 'DEALER', etc.
  name          String
  email         String
  phone         String?
  company       String?
  message       String?  @db.Text
  data          Json?    @default("{}") // Armazena campos complexos: produto, anexoUrl, urgência, cnpj, etc.
  status        String   @default("PENDENTE") // PENDENTE, EM_ATENDIMENTO, CONCLUIDO, CANCELADO
  internalNotes String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
